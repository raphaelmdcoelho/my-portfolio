---
import { config } from '../../data/config';
---

<section id="contact" style="padding-top: 6rem; padding-bottom: 6rem;" aria-label="Contact">
  <div class="content-wrap text-center">
    <h2 class="section-title justify-center"><span>#</span> Contact</h2>
    <div class="section-divider mx-auto"></div>

    <p class="mb-10 text-lg leading-relaxed" style="color: var(--color-muted);">
      Have a project in mind, want to collaborate, or just want to say hi?<br />
      Find me on the links below.
    </p>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-8">
      <a
        href={config.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 font-mono text-sm transition-colors duration-200"
        style="color: var(--color-muted);"
        aria-label="GitHub profile"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        GitHub
      </a>
      <a
        href={config.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 font-mono text-sm transition-colors duration-200"
        style="color: var(--color-muted);"
        aria-label="LinkedIn profile"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        LinkedIn
      </a>
      <a
        href={config.social.medium}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 font-mono text-sm transition-colors duration-200"
        style="color: var(--color-muted);"
        aria-label="Medium profile"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z" />
        </svg>
        Medium
      </a>
    </div>
  </div>
</section>

<style>
  .social-link:hover {
    color: var(--color-accent) !important;
  }
</style>
