---
import { config } from '../../data/config';
---

<section id="about" class="section" aria-label="About me">
  <div class="content-wrap">
    <h2 class="section-title"><span>#</span> About Me</h2>
    <div class="section-divider"></div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div>
        <div class="space-y-4">
          {
            config.bio.split('\n').filter(Boolean).map((paragraph) => (
              <p class="about-bio leading-relaxed">
                {paragraph.trim()}
              </p>
            ))
          }
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={config.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="about-link font-mono text-sm px-4 py-2 rounded border transition-all duration-200"
          >
            GitHub
          </a>
          <a
            href={config.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="about-link font-mono text-sm px-4 py-2 rounded border transition-all duration-200"
          >
            LinkedIn
          </a>
          <a
            href={config.social.medium}
            target="_blank"
            rel="noopener noreferrer"
            class="about-link font-mono text-sm px-4 py-2 rounded border transition-all duration-200"
          >
            Medium
          </a>
        </div>
      </div>

      <!-- Avatar -->
      <div class="flex justify-center md:justify-end">
        <div class="avatar-frame relative w-64 h-64 rounded-2xl overflow-hidden">
          <img
            src={config.avatar}
            alt={`Portrait of ${config.name}`}
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <!-- Fallback placeholder -->
          <div
            class="avatar-fallback absolute inset-0 items-center justify-center flex-col gap-2"
            style="display: none;"
            aria-hidden="true"
          >
            <svg class="avatar-fallback-icon" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <circle cx="12" cy="8" r="4" />
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
            <span class="avatar-fallback-label font-mono text-xs">avatar.jpg</span>
          </div>

          <!-- Corner accents -->
          <div class="corner-tl absolute top-0 right-0 w-8 h-8" aria-hidden="true"></div>
          <div class="corner-br absolute bottom-0 left-0 w-8 h-8" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-bio {
    color: var(--color-muted);
  }

  .about-link {
    color: var(--color-accent);
    border-color: var(--color-border);
  }

  .about-link:hover {
    background: var(--color-accent-dim);
    border-color: var(--color-accent) !important;
  }

  .avatar-frame {
    border: 1px solid var(--color-border);
    box-shadow: 0 0 40px var(--color-accent-dim);
  }

  .avatar-fallback {
    background: var(--color-surface-2);
  }

  .avatar-fallback-icon {
    color: var(--color-muted);
  }

  .avatar-fallback-label {
    color: var(--color-muted);
  }

  .corner-tl {
    border-top: 2px solid var(--color-accent);
    border-right: 2px solid var(--color-accent);
  }

  .corner-br {
    border-bottom: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
  }
</style>
