---
import { projects } from '../../data/projects';
import ProjectCard from '../ui/ProjectCard.astro';
---

<section id="projects" style="padding-top: 6rem; padding-bottom: 6rem;" aria-label="Projects">
  <div class="content-wrap">
    <h2 class="section-title reveal reveal-left"><span>#</span> Projects</h2>
    <div class="section-divider reveal"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6 reveal-stagger">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
