---
import type { BlogPost } from '../../data/blog';

interface Props {
  post: BlogPost;
}
const { post } = Astro.props;

const [year, month, day] = post.date.split('-').map(Number);
const formattedDate = new Date(year, month - 1, day).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card relative rounded-xl border flex flex-col transition-all duration-300">
  <!-- Hover fill overlay -->
  <div class="fill-overlay absolute inset-0 z-0 pointer-events-none rounded-xl" aria-hidden="true"></div>

  <div class="relative z-10 flex flex-col flex-1">
    <div class="flex items-center gap-3 mb-3">
      <time datetime={post.date} class="blog-date font-mono text-xs">
        {formattedDate}
      </time>
      {
        post.tags?.map((tag) => (
          <span class="tag">{tag}</span>
        ))
      }
    </div>

    <h3 class="blog-title font-mono font-bold text-base mb-3 leading-snug">
      {post.title}
    </h3>

    <p class="blog-excerpt text-sm leading-relaxed flex-1 mb-5">
      {post.excerpt}
    </p>

    <a
      href={post.url}
      class="blog-read-link font-mono text-sm flex items-center gap-1 transition-colors duration-200 mt-auto w-fit"
      aria-label={`Read more: ${post.title}`}
    >
      Read more
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--color-surface-2);
    border-color: var(--color-border);
    padding: 1.75rem;
  }

  .blog-card:hover {
    border-color: var(--color-accent) !important;
    transform: translateY(-3px);
  }

  .blog-date {
    color: var(--color-accent);
  }

  .blog-title {
    color: var(--color-text);
  }

  .blog-excerpt {
    color: var(--color-muted);
  }

  .blog-read-link {
    color: var(--color-accent);
  }

  .blog-read-link:hover {
    gap: 0.5rem;
  }

  .fill-overlay {
    background: var(--color-accent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .blog-card:hover .fill-overlay {
    opacity: 0.18;
  }
</style>
